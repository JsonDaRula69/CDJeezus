# CDJeezus configuration
# Generated by `cdjeezus setup`

# Soulseek credentials (required)
SLSK_USERNAME=your_soulseek_username
SLSK_PASSWORD=your_soulseek_password

# SoundCloud user URL (all playlists monitored automatically)
SOUNDCLOUD_USER_URL=https://soundcloud.com/your-username

# Primary DJ software: serato or rekordbox
PRIMARY_DJ=serato

# Poll interval in seconds (default: 300 = 5 min)
SOUNDCLOUD_POLL_INTERVAL=300

# Download directory (Serato Auto Import watches this folder)
# Default: ~/Music/_Serato_/Auto Import
DOWNLOAD_DIR=

# Staging directory (files downloaded/tagged here before moving to DOWNLOAD_DIR)
# Default: ~/.config/cdjeezus/staging
STAGING_DIR=

# Serato database directory
# Default: ~/Music/_Serato_
SERATO_DIR=

# Search preferences
SEARCH_TIMEOUT=30
PREFER_FREE_SLOTS=1
MIN_FILESIZE_MB=5

# Audio fingerprinting (optional but recommended)
FINGERPRINT_VERIFY=1
ACOUSTID_API_KEY=

# Library backups
BACKUP_ENABLED=0
BACKUP_SERATO=0
BACKUP_REKORDBOX=0

# Auto-update check interval in seconds (default: 14400 = 4 hours)
AUTO_UPDATE_INTERVAL=14400
